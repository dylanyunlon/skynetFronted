+
+export function getAllCategories(): CommandCategory[] {
+  const cats = new Set<CommandCategory>();
+  for (const info of Object.values(COMMAND_REGISTRY)) {
+    cats.add(info.category);
+  }
+  return Array.from(cats);
+}
