+// ── Collapsible Panel ────────────────────────────────────────────
+function CollapsibleBlock({ type, event, index, isExpanded, onToggle }) {
+  const cmdDef = COMMAND_TYPES[type] || { label: type, icon: "zap", color: "#6b7280", category: "tool" };
+  const catMeta = CATEGORY_META[cmdDef.category] || { label: "Other", bg: "#1c1917" };
+  const IconSvg = Icons[cmdDef.icon] || Icons.zap;
+
+  const isError = type === "tool_error" || event.data?.is_error;
+  const isSuccess = event.data?.status === "success" || event.data?.status === "pass" || type === "tool_result";
+
+  return (
+    <div style={{
+      marginBottom: 2,
+      borderRadius: 8,
+      overflow: "hidden",
+      border: `1px solid ${isError ? "rgba(239,68,68,0.3)" : isExpanded ? "rgba(255,255,255,0.12)" : "rgba(255,255,255,0.06)"}`,
+      background: isExpanded ? "rgba(255,255,255,0.03)" : "transparent",
+      transition: "all 0.2s ease",
+    }}>
+      {/* Header */}
+      <button
+        onClick={onToggle}
+        style={{
+          width: "100%",
+          display: "flex",
+          alignItems: "center",
+          gap: 10,
+          padding: "10px 14px",
+          background: "none",
+          border: "none",
+          cursor: "pointer",
+          color: "#e2e8f0",
+          fontFamily: "'IBM Plex Mono', 'Fira Code', monospace",
+          fontSize: 13,
+          textAlign: "left",
+        }}
+      >
+        {/* Icon */}
+        <span style={{
+          width: 22, height: 22, display: "flex", alignItems: "center", justifyContent: "center",
+          color: cmdDef.color, flexShrink: 0, opacity: 0.9,
+        }}>
+          {IconSvg}
+        </span>
+
+        {/* Label */}
+        <span style={{ fontWeight: 600, color: cmdDef.color, minWidth: 140 }}>
+          {cmdDef.label}
+        </span>
+
+        {/* Message / Description */}
+        <span style={{ flex: 1, color: "rgba(255,255,255,0.55)", fontSize: 12, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>
+          {event.data?.message || event.data?.command || event.data?.path || event.data?.text?.slice(0, 80) || ""}
+        </span>
+
+        {/* Status badge */}
+        {isError && (
+          <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 99, background: "rgba(239,68,68,0.2)", color: "#fca5a5", fontWeight: 600 }}>
+            ERROR
+          </span>
+        )}
+        {isSuccess && (
+          <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 99, background: "rgba(34,197,94,0.2)", color: "#86efac", fontWeight: 600 }}>
+            ✓
+          </span>
+        )}
+
+        {/* Timestamp */}
+        <span style={{ fontSize: 11, color: "rgba(255,255,255,0.3)", fontVariantNumeric: "tabular-nums", flexShrink: 0 }}>
+          {event.ts}
+        </span>
+
+        {/* Chevron */}
+        <span style={{
+          fontSize: 11, color: "rgba(255,255,255,0.3)", transform: isExpanded ? "rotate(90deg)" : "rotate(0deg)",
+          transition: "transform 0.15s ease", flexShrink: 0,
+        }}>
+          ▶
+        </span>
+      </button>
+
+      {/* Expanded Content */}
+      {isExpanded && (
+        <div style={{
+          padding: "0 14px 12px 46px",
+          fontSize: 12,
+          lineHeight: 1.6,
+        }}>
+          {/* Command line */}
+          {event.data?.command && (
+            <div style={{
+              background: "rgba(0,0,0,0.4)",
+              borderRadius: 6,
+              padding: "8px 12px",
+              marginBottom: 8,
+              fontFamily: "'IBM Plex Mono', monospace",
+              color: "#22c55e",
+              fontSize: 11.5,
+              borderLeft: `3px solid ${cmdDef.color}`,
+            }}>
+              <span style={{ color: "rgba(255,255,255,0.4)" }}>$ </span>{event.data.command}
+            </div>
+          )}
+
+          {/* Path */}
+          {event.data?.path && (
+            <div style={{ color: "rgba(255,255,255,0.5)", marginBottom: 6, fontSize: 11 }}>
+              📂 {event.data.path}
+            </div>
+          )}
+
+          {/* URL */}
+          {event.data?.url && (
+            <div style={{ color: "#38bdf8", marginBottom: 6, fontSize: 11 }}>
+              🔗 {event.data.url}
+            </div>
+          )}
+
+          {/* Query */}
+          {event.data?.query && (
+            <div style={{ color: "#c4b5fd", marginBottom: 6, fontSize: 11 }}>
+              🔍 {event.data.query} — {event.data.results} results
+            </div>
+          )}
+
+          {/* Files list */}
+          {event.data?.files && (
+            <div style={{ marginBottom: 6 }}>
+              {event.data.files.map((f, i) => (
+                <div key={i} style={{ color: "#38bdf8", fontSize: 11 }}>📄 {f}</div>
+              ))}
+            </div>
+          )}
+
+          {/* Error */}
+          {event.data?.error && (
+            <div style={{
+              background: "rgba(239,68,68,0.1)",
+              borderRadius: 6,
+              padding: "8px 12px",
+              color: "#fca5a5",
+              fontFamily: "'IBM Plex Mono', monospace",
+              fontSize: 11,
+              borderLeft: "3px solid #ef4444",
+            }}>
+              {event.data.error}
+            </div>
+          )}
+
+          {/* Result output */}
+          {event.data?.result && (
+            <pre style={{
+              background: "rgba(0,0,0,0.5)",
+              borderRadius: 6,
+              padding: "10px 12px",
+              color: "rgba(255,255,255,0.75)",
+              fontFamily: "'IBM Plex Mono', monospace",
+              fontSize: 11,
+              lineHeight: 1.5,
+              whiteSpace: "pre-wrap",
+              wordBreak: "break-all",
+              margin: 0,
+              maxHeight: 220,
+              overflowY: "auto",
+            }}>
+              {event.data.result}
+            </pre>
+          )}
+
+          {/* Text content (thinking, text blocks) */}
+          {event.data?.text && !event.data?.result && (
+            <div style={{
+              color: "rgba(255,255,255,0.65)",
+              fontStyle: type.includes("thinking") ? "italic" : "normal",
+              padding: "4px 0",
+              borderLeft: type.includes("thinking") ? "3px solid rgba(245,158,11,0.4)" : "none",
+              paddingLeft: type.includes("thinking") ? 12 : 0,
+            }}>
+              {event.data.text}
+            </div>
+          )}
+
+          {/* Summary */}
+          {event.data?.summary && (
+            <div style={{
+              color: "#fbbf24", fontSize: 11.5, fontStyle: "italic",
+              borderLeft: "3px solid rgba(245,158,11,0.3)", paddingLeft: 10,
+            }}>
+              {event.data.summary}
+            </div>
+          )}
+
+          {/* Rate limit info */}
+          {event.data?.utilization_5h !== undefined && (
+            <div style={{ display: "flex", gap: 16, marginTop: 4 }}>
+              <LimitBar label="5h window" value={event.data.utilization_5h} />
+              <LimitBar label="7d window" value={event.data.utilization_7d} />
+            </div>
+          )}
+
+          {/* Stop reason */}
+          {event.data?.stop_reason && (
+            <div style={{ color: "#a78bfa", fontSize: 11 }}>
+              Stop reason: <strong>{event.data.stop_reason}</strong>
+            </div>
+          )}
+
+          {/* Host info */}
+          {event.data?.host && (
+            <div style={{ color: "rgba(255,255,255,0.5)", fontSize: 11 }}>
+              🖥 {event.data.user}@{event.data.host}
+            </div>
+          )}
+
+          {/* Model info */}
+          {event.data?.model && (
+            <div style={{ color: "rgba(255,255,255,0.5)", fontSize: 11 }}>
+              🤖 Model: {event.data.model} | ID: {event.data.id}
+            </div>
+          )}
+        </div>
+      )}
+    </div>
+  );
+}
+
+function LimitBar({ label, value }) {
+  const pct = Math.round(value * 100);
+  const color = pct > 80 ? "#ef4444" : pct > 50 ? "#eab308" : "#22c55e";
+  return (
+    <div style={{ flex: 1 }}>
+      <div style={{ fontSize: 10, color: "rgba(255,255,255,0.4)", marginBottom: 3 }}>{label}</div>
+      <div style={{ height: 6, borderRadius: 3, background: "rgba(255,255,255,0.1)", overflow: "hidden" }}>
+        <div style={{ height: "100%", width: `${pct}%`, background: color, borderRadius: 3, transition: "width 0.5s ease" }} />
+      </div>
+      <div style={{ fontSize: 10, color, marginTop: 2 }}>{pct}%</div>
+    </div>
+  );
+}
+
+// ── Category Filter Chip ─────────────────────────────────────────
+function CategoryChip({ catKey, meta, active, onClick, count }) {
+  return (
+    <button
+      onClick={onClick}
+      style={{
+        display: "inline-flex",
+        alignItems: "center",
+        gap: 6,
+        padding: "5px 12px",
+        borderRadius: 99,
+        border: active ? "1px solid rgba(255,255,255,0.25)" : "1px solid rgba(255,255,255,0.08)",
+        background: active ? "rgba(255,255,255,0.1)" : "transparent",
+        color: active ? "#e2e8f0" : "rgba(255,255,255,0.4)",
+        cursor: "pointer",
+        fontSize: 11,
+        fontFamily: "'IBM Plex Mono', monospace",
+        fontWeight: active ? 600 : 400,
+        transition: "all 0.15s ease",
+        whiteSpace: "nowrap",
+      }}
+    >
+      {meta.label}
+      <span style={{
+        fontSize: 10,
+        padding: "1px 6px",
+        borderRadius: 99,
+        background: active ? "rgba(255,255,255,0.15)" : "rgba(255,255,255,0.05)",
+      }}>
+        {count}
+      </span>
+    </button>
+  );
+}
+
+// ── Command Type Reference Card ──────────────────────────────────
+function TypeReferenceGrid({ filter }) {
+  const entries = Object.entries(COMMAND_TYPES).filter(
+    ([, v]) => !filter || v.category === filter
+  );
+  return (
+    <div style={{
+      display: "grid",
+      gridTemplateColumns: "repeat(auto-fill, minmax(220px, 1fr))",
+      gap: 6,
+      marginBottom: 20,
+    }}>
+      {entries.map(([key, def]) => (
+        <div key={key} style={{
+          display: "flex",
+          alignItems: "center",
+          gap: 8,
+          padding: "7px 10px",
+          borderRadius: 6,
+          background: "rgba(255,255,255,0.02)",
+          border: "1px solid rgba(255,255,255,0.06)",
+          fontSize: 11,
+          fontFamily: "'IBM Plex Mono', monospace",
+        }}>
+          <span style={{ width: 16, height: 16, color: def.color, flexShrink: 0, display: "flex" }}>
+            {Icons[def.icon] || Icons.zap}
+          </span>
+          <span style={{ color: def.color, fontWeight: 600, minWidth: 0, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>
+            {def.label}
+          </span>
+          <span style={{ marginLeft: "auto", color: "rgba(255,255,255,0.2)", fontSize: 9, flexShrink: 0 }}>
+            {CATEGORY_META[def.category]?.label}
+          </span>
+        </div>
+      ))}
+    </div>
+  );
+}
